# ============================================================
#  VARIABLES DE ENTORNO — Intercambios Académicos
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas el .env real al repositorio.
# ============================================================

# --- Base de datos PostgreSQL (Neon / RDS) ---
DATABASE_URL=postgresql://usuario:password@host/nombre_bd?sslmode=require

# --- Autenticación JWT ---
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRATION_HOURS=24

# --- Correo (Gmail SMTP) ---
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASSWORD=tu_app_password_de_gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# --- AWS S3 (solo para desarrollo local; en EC2 se usa IAM Role automáticamente) ---
AWS_S3_BUCKET=intercambios-upc-docs
AWS_REGION=us-east-2
# AWS_ACCESS_KEY_ID=     # solo local, NO en producción
# AWS_SECRET_ACCESS_KEY= # solo local, NO en producción
